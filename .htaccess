# ==========================
# EDS — Canonical + Clean URLs -> pages-php/*.php
# ==========================

RewriteEngine On

# --------------------------------------------------
# Legacy public routes with clear modern equivalents
# --------------------------------------------------
RewriteRule ^casting/?$ /casting-matrix [R=301,L]
RewriteRule ^what-we-do(/.*)?$ /eds-differentials [R=301,L]
RewriteRule ^add-value/?$ /eds-differentials [R=301,L]
RewriteRule ^logistics/?$ /eds-differentials [R=301,L]
RewriteRule ^terms-conditions/?$ /terms [R=301,L]
RewriteRule ^terms-and-conditions/?$ /terms [R=301,L]

# Redirect old direct access before blocking implementation folders.
RewriteCond %{REQUEST_METHOD} POST
RewriteRule ^pages-php/new-leads\.php$ /new-leads [R=307,L]

RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} \s/+pages-php/(add-value|logistics)\.php(?:\?|\s) [NC]
RewriteRule ^pages-php/(add-value|logistics)\.php$ /eds-differentials [R=301,L]

RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} \s/+pages-php/([^\s?]+)\.php(?:\?|\s) [NC]
RewriteRule ^pages-php/(.+)\.php$ /$1 [R=301,L]

# --------------------------------------------------
# Internal folders must not be browser-accessible
# --------------------------------------------------
RewriteRule ^(data|docs|includes|config)(/|$) - [F,L]

# Block direct requests to implementation files while allowing clean URL rewrites.
RewriteCond %{THE_REQUEST} \s/+pages-php/ [NC]
RewriteRule ^pages-php/ - [F,L]

# --------------------------------------------------
# A) Force HTTPS
# --------------------------------------------------
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --------------------------------------------------
# B) Remove /index.php from URLs
# --------------------------------------------------
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s/]|$) [NC]
RewriteRule ^index\.php/?(.*)$ /$1 [R=301,L]

# --------------------------------------------------
# D) Do not rewrite real files or directories
# --------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# --------------------------------------------------
# E) Route clean URLs through the canonical resolver
# --------------------------------------------------

# app.php normalizes trailing slashes and URL case, then resolves pages-php.
RewriteRule ^ app.php [L]
